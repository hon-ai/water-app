{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Water",
  "version": "0.1.0",
  "identifier": "co.water.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter @water/app dev",
    "beforeBuildCommand": "pnpm --filter @water/app build"
  },
  "app": {
    "windows": [
      {
        "title": "Water",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi", "nsis"],
    "icon": ["icons/icon.ico"]
  }
}
