{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Water",
  "version": "0.1.0",
  "identifier": "co.water.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "pnpm --filter @water/app dev",
    "beforeBuildCommand": "pnpm --filter @water/app build"
  },
  "app": {
    "windows": [
      {
        "title": "Water",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi", "nsis"],
    "icon": ["icons/icon.ico"],
    "resources": {
      "../../sidecar/pyproject.toml": "sidecar/pyproject.toml",
      "../../sidecar/uv.lock": "sidecar/uv.lock",
      "../../sidecar/README.md": "sidecar/README.md",
      "../../sidecar/src/water_sidecar/**/*": "sidecar/src/water_sidecar/"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/hon-ai/water-app/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_PUBLIC_KEY_FROM_TAURI_SIGNER_GENERATE",
      "dialog": false
    }
  }
}
